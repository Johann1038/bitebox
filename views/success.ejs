<%- include('partials/header') %>

<%
  // Build the WhatsApp message on the server side
  let waUrl = '';
  if (order && order.status === 'COMPLETED' && whatsappNumber) {
    const itemLines = order.items
      .map(i => `  • ${i.name} × ${i.quantity} — $${(i.price * i.quantity).toFixed(2)}`)
      .join('\n');

    const msg = [
      '🛍️ *New BiteBox Order!*',
      '',
      `📋 *Order Ref:* #${order.ref}`,
      `👤 *Customer:* ${order.customerName || order.payerName}`,
      `📱 *Phone:* ${order.customerPhone || 'N/A'}`,
      `📧 *Email:* ${order.payerEmail}`,
      '',
      '🧾 *Items Ordered:*',
      itemLines,
      '',
      `💰 *Total Paid: $${Number(order.total).toFixed(2)}*`,
      `💳 *Transaction ID:* ${order.captureId}`,
      '',
      '✅ Payment received via PayPal',
    ].join('\n');

    waUrl = `https://wa.me/${whatsappNumber}?text=${encodeURIComponent(msg)}`;
  }
%>

<div class="page-container" style="max-width:660px; margin:0 auto;">
  <div class="result-card">

    <% if (order && order.status === 'COMPLETED') { %>

      <div class="result-icon">🎉</div>
      <h1 style="color:#16a34a; font-family:'Playfair Display',serif;">Payment Successful!</h1>
      <p>Thank you, <strong><%= order.customerName || order.payerName %></strong>! Your order has been placed.</p>

      <!-- Transaction details -->
      <div class="detail-grid">
        <div class="detail-row">
          <span class="detail-label">Order Ref</span>
          <span class="detail-value">#<%= order.ref %></span>
        </div>
        <div class="detail-row">
          <span class="detail-label">Customer</span>
          <span class="detail-value"><%= order.customerName || order.payerName %></span>
        </div>
        <div class="detail-row">
          <span class="detail-label">Phone</span>
          <span class="detail-value"><%= order.customerPhone || '—' %></span>
        </div>
        <div class="detail-row">
          <span class="detail-label">Email</span>
          <span class="detail-value"><%= order.payerEmail %></span>
        </div>
        <div class="detail-row">
          <span class="detail-label">Amount Paid</span>
          <span class="detail-value" style="color:var(--orange,#f97316);">$<%= Number(order.total).toFixed(2) %></span>
        </div>
        <div class="detail-row">
          <span class="detail-label">Transaction ID</span>
          <span class="detail-value" style="font-size:0.78rem; word-break:break-all;"><%= order.captureId %></span>
        </div>
        <div class="detail-row">
          <span class="detail-label">Date</span>
          <span class="detail-value"><%= new Date(order.capturedAt).toLocaleString() %></span>
        </div>
      </div>

      <!-- Items ordered -->
      <h3 style="font-size:0.88rem; color:#888; font-weight:700; text-transform:uppercase; letter-spacing:.6px; margin-bottom:.7rem;">
        Items Ordered
      </h3>
      <div class="detail-grid">
        <% order.items.forEach(item => { %>
          <div class="detail-row">
            <span class="detail-label"><%= item.name %> × <%= item.quantity %></span>
            <span class="detail-value">$<%= (item.price * item.quantity).toFixed(2) %></span>
          </div>
        <% }) %>
      </div>

      <!-- Actions -->
      <div class="success-actions">
        <% if (waUrl) { %>
          <a href="<%= waUrl %>" target="_blank" class="btn btn-whatsapp">
            <span class="wa-icon">📲</span>
            Send Order on WhatsApp
          </a>
        <% } %>
        <a href="/" class="btn btn-outline btn-lg">Order Again</a>
      </div>

      <% if (!whatsappNumber) { %>
        <p style="margin-top:1rem; font-size:0.78rem; color:#bbb;">
          (Set <code>WHATSAPP_NUMBER</code> in .env to enable WhatsApp notifications)
        </p>
      <% } %>

    <% } else { %>

      <div class="result-icon">❓</div>
      <h1 style="font-family:'Playfair Display',serif;">Order Not Found</h1>
      <p>We couldn't find that order. It may have expired from memory.</p>
      <a href="/" class="btn btn-primary btn-lg" style="margin-top:1rem; display:inline-block;">Back to Menu</a>

    <% } %>

  </div>
</div>

<%- include('partials/footer') %>
